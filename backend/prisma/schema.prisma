// Prisma Schema for Microsoft SQL Server (MSSQL)
// LogHorizon - Project Infrastructure

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed
  role      String   @default("USER") // "ADMIN", "USER"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences UserPreference[]
}

model Content {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   // "Anime", "Manga", "Movie", "Book", "TV"
  description String   @db.NVarChar(MAX)
  discordLink String?
  spotifyId   String?
  
  // Ingestion fields
  externalId  String?  // ID from source API
  source      String?  // "Jikan", "AniList", "TMDB", "GoogleBooks"
  coverImage  String?  @db.NVarChar(MAX)
  rating      Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        ContentTag[]
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // "Mood", "Genre"
  createdAt DateTime @default(now())

  users    UserPreference[]
  contents ContentTag[]

  @@unique([name, type])
}

model ContentTag {
  contentId Int
  tagId     Int

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}

model UserPreference {
  userId Int
  tagId  Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}
