// Prisma Schema

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  User
  Admin
}

enum PreferenceType {
  Genre
  Theme
  Mood
}

enum TagType {
  Genre
  Mood
}

model User {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  email        String           @unique
  passwordHash String
  role         UserRole         @default(User)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  preferences  UserPreference[]
}

model PreferenceOption {
  id        Int              @id @default(autoincrement())
  type      PreferenceType
  value     String
  createdAt DateTime         @default(now())

  users     UserPreference[]

  @@unique([type, value])
}

model UserPreference {
  userId             Int
  preferenceOptionId Int
  createdAt          DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  option PreferenceOption @relation(fields: [preferenceOptionId], references: [id], onDelete: Cascade)

  @@id([userId, preferenceOptionId])
}

model Content {
  id          Int          @id @default(autoincrement())
  title       String
  category    String
  description String
  discordLink String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tags        ContentTag[]
}

model Tag {
  id        Int       @id @default(autoincrement())
  type      TagType
  name      String
  createdAt DateTime  @default(now())

  contents  ContentTag[]

  @@unique([type, name])
}

model ContentTag {
  contentId Int
  tagId     Int

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}